# ──────────────────────────────────────────────
# AI Tutor Agent — Environment Configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# === LLM ===
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o                      # swappable via LiteLLM (e.g. gemini/gemini-pro)
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# === Embeddings ===
EMBEDDING_MODEL=text-embedding-3-small

# === ChromaDB ===
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=ai_tutor_docs

# === RAG ===
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MMR_K=6
MMR_FETCH_K=20
RELEVANCE_THRESHOLD=0.35

# === LangSmith Tracing (optional) ===
LANGCHAIN_TRACING_V2=false            # set to true to enable
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ai-tutor-agent

# === Streamlit ===
STREAMLIT_PORT=8501

# === Export ===
EXPORT_DIR=./exports
